# Server configuration
PORT=5000
NODE_ENV=development

# Database connections
# PostgreSQL (Primary Database - requires pgvector for similarity searches)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/writers_pub

# MongoDB (Legacy/Co-existence features - optional)
MONGO_URI=mongodb://localhost:27017/writers-pub

# Redis cache and rate limiting connection
REDIS_URL=redis://localhost:6379

# Authentication (JWT Secrets - use strong, random secrets in production)
JWT_SECRET=your_jwt_access_secret_key_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Third-party integrations (Google Gemini AI API Key)
GEMINI_API_KEY=your_google_gemini_api_key_here

# OAuth credentials (optional, for branding/oauth integration)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Frontend Application URL
FRONTEND_URL=http://localhost:3000

# Server options
ALLOW_DEGRADED_START=false
